
# Replace [PASSWORD] with your actual database password
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres?sslmode=require"

# Direct database URL for migrations (non-pooled connection)

DIRECT_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres"

# ============================================================
# AUTHENTICATION & SECURITY
# ============================================================
# JWT Secret for token signing and verification
# IMPORTANT: Use a cryptographically secure random string
# Minimum 32 characters recommended for production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-secure-random-string-minimum-32-characters-long-use-crypto"

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
# Public API URL for frontend API calls
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_API_URL="http://localhost:3000"

